# .gitignore

# 🔑 Private Environment Secrets (CRITICAL)
.env
.env.*
*.env

# 🐍 Backend (Python) Ignore Rules
__pycache__/
*.py[cod]
*$py.class
.venv/
venv/
ENV/
.pytest_cache/

# ⚛️ Frontend (React/Vite) Ignore Rules
node_modules/
dist/
dist-ssr/
*.local

# 🏢 OS & IDE Files
.DS_Store
.vscode/
.idea/
